# Copy these into Railway → your service → Variables
# MySQL vars (MYSQLHOST, MYSQLPORT, etc.) are injected automatically when you add a MySQL plugin.

# Required
JWT_SECRET=your-256-bit-or-longer-secret-here
GOOGLE_CLIENT_IDS=your-web-client-id.apps.googleusercontent.com,your-android-client-id.apps.googleusercontent.com
GUARDIAN_API_KEY=your-guardian-api-key

# Optional
JWT_EXPIRATION_MS=86400000
SPRING_PROFILES_ACTIVE=prod
